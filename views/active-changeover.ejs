<!DOCTYPE html>
<html>
<head>
<title>Changeover Running</title>
<link rel="stylesheet" href="/css/style.css">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="/favicon.png" type="image/png">
</head>

<body>

<div class="topbar">

<button id="menuToggle">☰</button>

<h1>Changeover Monitoring System</h1>

<div class="topbar-right">
<span class="welcome-text">Welcome, User</span>
<a href="/" class="logout-btn">Logout</a>
</div>

</div>

<div id="overlay"></div>

<div class="sidebar" id="sidebar">
<h2>Changeover</h2>
<ul>
<li><a href="/dashboard">Dashboard</a></li>
<li><a href="/new-changeover">New Changeover</a></li>
<li><a href="/past-changeovers">Past Changeovers</a></li>
<li><a href="/reports">Reports</a></li>
<li>
<a href="/pending-analysis">
Post Changeover Analysis
<span class="notification"><%= pendingCount %></span>
</a>
</li>
</ul>
</div>

<div class="main-content">

<div class="card">

<h2>
<%= changeover.from_style %> → <%= changeover.to_style %>
</h2>

<p>Line: <%= changeover.line %></p>

<h1 id="timer">00:00:00</h1>

<div class="action-buttons">

<form action="/stop/<%= changeover.id %>" method="POST">
<button type="submit" class="btn stop-btn">
  ⛔ Stop
</button>
</form>

<button id="pauseBtn" class="btn pause-btn">
  ⏸ Pause
</button>

<button id="resumeBtn" class="btn resume-btn" disabled>
  ▶ Resume
</button>

</div>

</div>

</div>

<script>

// ===================
// FINAL STABLE TIMER 
// ===================

let startTime = <%= new Date(changeover.start_time).getTime() %>;

let paused = false;
let pauseStart = 0;
let totalPausedTime = 0;

if (isNaN(startTime)) {
    startTime = Date.now();
}

function updateTimer(){

    if (paused) return;

    const now = Date.now();
    const diff = Math.floor((now - startTime - totalPausedTime) / 1000);

    const hours = Math.floor(diff / 3600);
    const minutes = Math.floor((diff % 3600) / 60);
    const seconds = diff % 60;

    document.getElementById("timer").innerText =
        String(hours).padStart(2,'0') + ":" +
        String(minutes).padStart(2,'0') + ":" +
        String(seconds).padStart(2,'0');
}

// Pause
document.getElementById("pauseBtn").addEventListener("click", () => {
    paused = true;
    pauseStart = Date.now();

    document.getElementById("pauseBtn").disabled = true;
    document.getElementById("resumeBtn").disabled = false;
});

// Resume
document.getElementById("resumeBtn").addEventListener("click", () => {
    paused = false;
    totalPausedTime += Date.now() - pauseStart;

    document.getElementById("pauseBtn").disabled = false;
    document.getElementById("resumeBtn").disabled = true;
});

updateTimer();
setInterval(updateTimer, 1000);

</script>

<script src="/js/sidebar.js"></script>

</body>
</html>
