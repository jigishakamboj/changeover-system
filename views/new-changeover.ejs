<!DOCTYPE html>
<html>
<head>
    <title>New Changeover</title>
    <link rel="stylesheet" href="/css/style.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/favicon.png">
</head>
<body>

<!-- Topbar -->
<div class="topbar">

<button id="menuToggle">☰</button>

<h1>Changeover Monitoring System</h1>

<div class="topbar-right">

<span class="welcome-text">
Welcome, User
</span>

<a href="/" class="logout-btn">
Logout
</a>

</div>

</div>

<!-- Overlay -->
<div id="overlay"></div>

<!-- Sidebar -->
<div class="sidebar" id="sidebar">
    <h2>Changeover</h2>
    <ul>
        <li><a href="/dashboard">Dashboard</a></li>
        <li><a href="/new-changeover">New Changeover</a></li>
        <li><a href="/past-changeovers">Past Changeovers</a></li>
        <li><a href="/reports">Reports</a></li>
        <li><a href="/pending-analysis">
        Post Changeover Analysis
        <span class="notification"><%= pendingCount %></span></a></li>
    </ul>
</div>

<div class="main-content">

<div class="card">

<h2>Plan New Changeover</h2>

<form action="<%= changeover ? '/update-changeover/' + changeover.id : '/new-changeover' %>" method="POST">

<h3 style="margin-top:30px;">Basic Information</h3>

<div class="form-grid">

<div class="form-group">
<label>Planned Date</label>
<input type="text" name="date" value="<%= changeover ? changeover.date : '' %>">
</div>

<div class="form-group">
<label>Line</label>
<input type="text" name="line" value="<%= changeover ? changeover.date : '' %>">
</div>

<div class="form-group">
<label>From Style</label>
<input type="text" name="from_style" value="<%= changeover ? changeover.date : '' %>">
</div>

<div class="form-group">
<label>From Product Type</label>
<input type="text" name="from_product_type">
</div>

<div class="form-group">
<label>To Style</label>
<input type="text" name="to_style" value="<%= changeover ? changeover.date : '' %>">
</div>

<div class="form-group">
<label>To Product Type</label>
<input type="text" name="to_product_type">
</div>

</div>


<h3 style="margin-top:40px;">Machine Types Required</h3>

<div class="form-group">

<label>Select Machines</label>

<div style="margin-top:10px;">

<label><input type="checkbox" name="machine_types" value="Single Needle"> Single Needle</label><br>
<label><input type="checkbox" name="machine_types" value="Overlock"> Overlock</label><br>
<label><input type="checkbox" name="machine_types" value="Flatlock"> Flatlock</label><br>
<label><input type="checkbox" name="machine_types" value="Feed Off Arm"> Feed Off Arm</label><br>
<label><input type="checkbox" name="machine_types" value="Buttonhole"> Buttonhole</label><br>
<label><input type="checkbox" name="machine_types" value="Bartack"> Bartack</label>
<label><input type="checkbox" name="machine_types" value="DNLS"> Double Needle</label>
<label><input type="checkbox" name="machine_types" value="Kansai"> Kansai</label>
<label><input type="checkbox" name="machine_types" value="Button attach"> Kaj button</label>
<label><input type="checkbox" name="machine_types" value="Tich button attach"> Snap button</label>
<label><input type="checkbox" name="machine_types" value="Edge cutter"> Edgecutter single needle</label>

</div>

</div>


<h3 style="margin-top:40px;">Machine Setup Requirements</h3>

<div class="form-grid">

<div class="form-group">
<label>Needle Requirements</label>
<input type="text" name="needle_req">
</div>

<div class="form-group">
<label>Throat Plate</label>
<input type="text" name="throat_plate">
</div>

<div class="form-group">
<label>Presser Foot</label>
<input type="text" name="presser_foot">
</div>

<div class="form-group">
<label>Feed Dog</label>
<input type="text" name="feed_dog">
</div>

</div>


<h3 style="margin-top:40px;">Attachments</h3>

<div class="form-grid">

<div class="form-group">
<label>Binders / Folders</label>
<input type="text" name="binders">
</div>

<div class="form-group">
<label>Attachments & Guides</label>
<input type="text" name="attachments">
</div>

<div class="form-group">
<label>Templates / Profiles</label>
<input type="text" name="templates">
</div>

</div>


<h3 style="margin-top:40px;">Process Notes</h3>

<div class="form-group">

<label>Critical Operations</label>

<textarea name="critical_operations" rows="4"></textarea>

</div>


<div style="margin-top:40px;">
<button type="submit">Create Changeover</button>
</div>

</form>

</div>

</div>

<script src="/js/sidebar.js"></script>

</body>
</html>
