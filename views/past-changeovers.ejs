<!DOCTYPE html>
<html>
<head>
<title>Past Changeovers</title>
<link rel="stylesheet" href="/css/style.css">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="/favicon.png" type="image/png">
</head>

<body>

<div class="topbar">
<button id="menuToggle">☰</button>
<h1>Changeover Monitoring System</h1>

<div class="topbar-right">
<span>Welcome, User</span>
<a href="/" class="logout-btn">Logout</a>
</div>
</div>

<div id="overlay"></div>

<div class="sidebar" id="sidebar">
<h2>Changeover</h2>
<ul>
<li><a href="/dashboard">Dashboard</a></li>
<li><a href="/new-changeover">New Changeover</a></li>
<li><a href="/past-changeovers">Past Changeovers</a></li>
<li><a href="/reports">Reports</a></li>
<li><a href="/pending-analysis">Post Changeover Analysis 
<span class="notification"><%= pendingCount %></span></a></li>
</ul>
</div>

<div class="main-content">

<% function formatLine(line){ 
    if(!line) return "";
    if(typeof line === "string" && line.includes("/")) return line;

    const d = new Date(line);
    if(!isNaN(d)) return d.getDate() + "/" + (d.getMonth()+1);

    return line;
} %>

<div class="card">

<div class="card-header">
  <h2>All Changeovers</h2>

  <button onclick="window.print()" class="primary-btn">
    Print Report
  </button>
</div>


<div class="filter-bar">

  <input 
    type="text" 
    id="search" 
    placeholder="Search style or line..."
    onkeyup="filterTable()"
  >

  <select id="sort" onchange="sortTable()">
    <option value="">Sort By</option>
    <option value="date">Date</option>
    <option value="duration">Duration</option>
    <option value="loss">Bucket Loss</option>
  </select>

</div>

<script>
function filterTable() {
  const input = document.getElementById("search").value.toLowerCase();
  const rows = document.querySelectorAll("table tbody tr");

  rows.forEach(row => {
    row.style.display = row.innerText.toLowerCase().includes(input)
      ? ""
      : "none";
  });
}

function sortTable() {
  const type = document.getElementById("sort").value;
  const tbody = document.querySelector("table tbody");
  const rows = Array.from(tbody.querySelectorAll("tr"));

  const indexMap = {
    date: 1,
    duration: 5,
    loss: 6
  };

  const index = indexMap[type];

  if (!index) return;

  rows.sort((a, b) => {
    let A = a.children[index].innerText;
    let B = b.children[index].innerText;

    return type === "date"
      ? new Date(A) - new Date(B)
      : Number(A) - Number(B);
  });

  tbody.innerHTML = "";
  rows.forEach(r => tbody.appendChild(r));
}
</script>

<script>
function filterTable() {
  const input = document.getElementById("search").value.toLowerCase();
  const rows = document.querySelectorAll("table tbody tr");

  rows.forEach(row => {
    row.style.display = row.innerText.toLowerCase().includes(input)
      ? ""
      : "none";
  });
}

function sortTable() {
  const type = document.getElementById("sort").value;
  const tbody = document.querySelector("table tbody");
  const rows = Array.from(tbody.querySelectorAll("tr"));

  const indexMap = {
    date: 1,
    duration: 5,
    loss: 6
  };

  const index = indexMap[type];

  if (!index) return;

  rows.sort((a, b) => {
    let A = a.children[index].innerText;
    let B = b.children[index].innerText;

    return type === "date"
      ? new Date(A) - new Date(B)
      : Number(A) - Number(B);
  });

  tbody.innerHTML = "";
  rows.forEach(r => tbody.appendChild(r));
}
</script>

<table style="width:100%; margin-top:20px;">
<thead>
<tr>
<th>CO ID</th>
<th>Date</th>
<th>Line</th>
<th>From Style</th>
<th>To Style</th>
<th>Duration</th>
<th>Bucket Loss</th>
<th>Status</th>
<th>Action</th>
</tr>
</thead>

<tbody>

<% changeovers.forEach(co => { %>
<tr>
<td><%= co.changeover_id %></td>
<td>

<%
function formatDate(d) {
  if (!d) return "No Date";

  if (typeof d === "string" && d.includes("-")) {
    const [year, month, day] = d.split("-");
    return `${day}/${month}/${year}`; // ✅ DD/MM/YYYY
  }

  return "Invalid Date";
}
%>

<%= formatDate(co.date) %></td>
<td><%= formatLine(co.line) %></td>
<td><%= co.from_style %></td>
<td><%= co.to_style %></td>
<td><%= co.final_minutes %></td>
<td><%= co.bucket_loss %></td>
<td><%= co.status %></td>
<td>
<a href="/edit-changeover/<%= co.id %>">
<button style="background:#2c3e50;color:white;border:none;padding:6px 12px;border-radius:4px;cursor:pointer;">
Edit
</button>
</a>
</td>
<td>
<form action="/delete/<%= co.id %>" method="POST">
<button style="background:red;color:white;border:none;padding:6px 12px;border-radius:4px;">
Delete
</button>
</form>
</td>
</tr>
<% }) %>

</tbody>
</table>

</div>
</div>

<script src="/js/sidebar.js"></script>
</body>
</html>
