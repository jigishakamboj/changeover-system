    <!DOCTYPE html>
<html>
<head>
    <title>Past Changeovers</title>
    <link rel="stylesheet" href="/css/style.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>
<body>

<!-- Topbar -->
<div class="topbar">

<button id="menuToggle">☰</button>

<h1>Changeover Monitoring System</h1>

<div class="topbar-right">

<span class="welcome-text">
Welcome, User
</span>

<a href="/" class="logout-btn">
Logout
</a>

</div>

</div>

<!-- Overlay -->
<div id="overlay"></div>

<!-- Sidebar -->
<div class="sidebar" id="sidebar">
    <h2>Changeover</h2>
    <ul>
        <li><a href="/dashboard">Dashboard</a></li>
        <li><a href="/new-changeover">New Changeover</a></li>
        <li><a href="/past-changeovers">Past Changeovers</a></li>
        <li><a href="/reports">Reports</a></li>
        <li><a href="/pending-analysis">
        Post Changeover Analysis
        <span class="notification"><%= pendingCount %></span></a></li>
    </ul>
</div>

<div class="main-content">

    <div class="card">

        <h2>All Changeovers</h2>

        <table style="width:100%; margin-top:20px; border-collapse: collapse;">

            <thead>
                <tr>
                    <th>CO ID</th>
                    <th>Date</th>
                    <th>Line</th>
                    <th>From Style</th>
                    <th>To Style</th>
                    <th>Duration (min)</th>
                    <th>Bucket Loss</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>

            <% changeovers.forEach(co => { %>

                <tr>
                    <td><%= co.changeover_id %></td>
                    <td><%= co.date %></td>
                    <td><%= co.line %></td>
                    <td><%= co.from_style %></td>
                    <td><%= co.to_style %></td>
                    <td><%= co.final_minutes %></td>
                    <td><%= co.bucket_loss %></td>
                    <td><%= co.status %></td>

                    <td>
                    <a href="/edit-changeover/<%= co.id %>">
                    <button style="background:#2c3e50;color:white;border:none;padding:6px 12px;border-radius:4px;cursor:pointer;">
                    Edit
                    </button>
                    </a>
                    </td>

                </tr>

            <% }) %>

            </tbody>

        </table>

    </div>

</div>

<script src="/js/sidebar.js"></script>

</body>
</html>