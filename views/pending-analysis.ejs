<!DOCTYPE html>
<html>
<head>

<title>Pending Post Changeover Analysis</title>

<link rel="stylesheet" href="/css/style.css">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="/favicon.png" type="image/png">
</head>

<body>

<!-- Topbar -->

<div class="topbar">

<button id="menuToggle">☰</button>

<h1>Changeover Monitoring System</h1>

<div class="topbar-right">

<span class="welcome-text">
Welcome, User
</span>

<a href="/" class="logout-btn">
Logout
</a>

</div>

</div>

<div id="overlay"></div>

<!-- Sidebar -->

<div class="sidebar" id="sidebar">
<h2>Changeover</h2>
<ul>
<li><a href="/dashboard">Dashboard</a></li>
<li><a href="/new-changeover">New Changeover</a></li>
<li><a href="/past-changeovers">Past Changeovers</a></li>
<li><a href="/reports">Reports</a></li>
<li><a href="/pending-analysis">Post Changeover Analysis<span class="notification"><%= pendingCount %></span>
</a></li>
</ul>
</div>

<!-- Main Content -->

<div class="main-content">

<% if(changeovers.length === 0){ %>

<p>No pending analysis.</p>

<% } %>

<% changeovers.forEach(co => { %>

<div class="card">

<h3>
<%= co.from_style %> → <%= co.to_style %>
</h3>

<p>Line: <%= co.line %></p>

<p>Duration: <%= co.final_minutes %> min</p>

<a href="/post-changeover/<%= co.id %>">
<div style="margin-top:10px;">
  <button class="primary-btn small-btn">
    Open Analysis →
  </button>
</div>
</a>

</div>

<% }) %>

</div>

<script src="/js/sidebar.js"></script>

</body>
</html>
