
<!DOCTYPE html>
<html>
<head>

<title>Post Changeover Analysis</title>
<link rel="stylesheet" href="/css/style.css">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="/favicon.png" type="image/png">
</head>

<body>

<div class="topbar">

<button id="menuToggle">☰</button>

<h1>Changeover Monitoring System</h1>

<div class="topbar-right">
<span class="welcome-text">Welcome, User</span>
<a href="/" class="logout-btn">Logout</a>
</div>

</div>

<div id="overlay"></div>

<div class="sidebar" id="sidebar">
<h2>Changeover</h2>
<ul>
<li><a href="/dashboard">Dashboard</a></li>
<li><a href="/new-changeover">New Changeover</a></li>
<li><a href="/past-changeovers">Past Changeovers</a></li>
<li><a href="/reports">Reports</a></li>
<li><a href="/pending-analysis">
Post Changeover Analysis
<span class="notification"><%= pendingCount %></span>
</a></li>
</ul>
</div>

<div class="main-content">

<% if(changeover){ %>

<div class="card">

<h2>
<%= changeover.from_style %> → <%= changeover.to_style %>
</h2>


<p>Line: <%= changeover.line %></p>
<p>Changeover Duration: <%= changeover.final_minutes %> minutes</p>

<form action="/post-changeover/<%= changeover.id %>" method="POST">

<h3 style="margin-top:25px;">Ramp-Up Monitoring</h3>

<div class="form-grid">

<div class="form-group">
<label>Ramp Up Days</label>
<input type="number" name="ramp_up_days" required>
</div>

<% } else { %>
  <p>Changeover not found.</p>
<% } %>

<div class="form-group">
<label>Ramp-Up Loss (pcs)</label>
<input type="number" id="rampLoss">
</div>

<div class="form-group">
<label>Changeover Loss (pcs)</label>
<input type="number" id="coLoss">
</div>

<div class="form-group">
<label>Total Bucket Loss</label>
<input type="number" name="bucket_loss" id="totalLoss" readonly>
</div>

</div>

<div class="form-group">
<label>Major Delay Causes</label>
<textarea name="major_delay"></textarea>
</div>

<div style="margin-top:20px; display:flex; gap:15px;">

<button type="submit" class="primary-btn">
Save Analysis
</button>

<a href="/dashboard" class="secondary-btn">
Do Later
</a>

</div>

</form>

</div>

</div>

<script>

const rampLoss = document.getElementById("rampLoss");
const coLoss = document.getElementById("coLoss");
const totalLoss = document.getElementById("totalLoss");

function calculateLoss(){

const ramp = Number(rampLoss.value)||0;
const co = Number(coLoss.value)||0;

totalLoss.value = ramp + co;

}

rampLoss.addEventListener("input",calculateLoss);
coLoss.addEventListener("input",calculateLoss);

</script>

<script src="/js/sidebar.js"></script>

</body>
</html>
