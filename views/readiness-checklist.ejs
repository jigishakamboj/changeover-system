<!DOCTYPE html>
<html>
<head>
<title>Pre-Changeover Readiness Checklist</title>
<link rel="stylesheet" href="/css/style.css">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>

<body>

<div class="topbar">
<button id="menuToggle">☰</button>
<h1>Changeover Monitoring System</h1>
</div>

<div id="overlay"></div>

<div class="sidebar" id="sidebar">
<h2>Changeover</h2>
<ul>
<li><a href="/dashboard">Dashboard</a></li>
<li><a href="/new-changeover">New Changeover</a></li>
<li><a href="/past-changeovers">Past Changeovers</a></li>
<li><a href="/reports">Reports</a></li>
<li><a href="/pending-analysis">Post Changeover Analysis</a></li>
</ul>
</div>

<div class="main-content">

<div class="card">

<h2>Pre-Changeover Readiness Checklist</h2>

<h3>
<%= changeover.from_style %>
</h3>

<p>Line: <%= changeover.line %></p>

<form method="POST">

<h3 style="margin-top:30px;">Material Readiness</h3>

<label>
<input type="checkbox" name="fabric_ready"
<%= changeover.fabric_ready ? "checked" : "" %>>
Fabric Received
</label><br>

<label>
<input type="checkbox" name="panels_ready"
<%= changeover.panels_ready ? "checked" : "" %>>
Cut Panels Received
</label><br>

<label>
<input type="checkbox" name="thread_ready"
<%= changeover.thread_ready ? "checked" : "" %>>
Thread Available
</label><br>

<label>
<input type="checkbox" name="trims_ready"
<%= changeover.trims_ready ? "checked" : "" %>>
Trims Received
</label><br>

<label>
<input type="checkbox" name="labels_ready"
<%= changeover.labels_ready ? "checked" : "" %>>
Labels Received
</label>

<h3 style="margin-top:25px;">Machine Preparation</h3>

<label>
<input type="checkbox" name="attachments_ready"
<%= changeover.attachments_ready ? "checked" : "" %>>
Attachments Ready
</label><br>

<label>
<input type="checkbox" name="needle_ready"
<%= changeover.needle_ready ? "checked" : "" %>>
Needle Confirmed
</label><br>

<label>
<input type="checkbox" name="presser_ready"
<%= changeover.presser_ready ? "checked" : "" %>>
Presser Foot Ready
</label><br>

<label>
<input type="checkbox" name="bobbins_ready"
<%= changeover.bobbins_ready ? "checked" : "" %>>
Bobbins Pre-Wound
</label>

<h3 style="margin-top:25px;">Technical Readiness</h3>

<label>
<input type="checkbox" name="techpack_ready"
<%= changeover.techpack_ready ? "checked" : "" %>>
Techpack Available
</label><br>

<label>
<input type="checkbox" name="operation_ready"
<%= changeover.operation_ready ? "checked" : "" %>>
Operation Breakdown Ready
</label><br>

<label>
<input type="checkbox" name="sample_ready"
<%= changeover.sample_ready ? "checked" : "" %>>
Sample Approved
</label><br>

<label>
<input type="checkbox" name="quality_ready"
<%= changeover.quality_ready ? "checked" : "" %>>
Quality Checkpoints Defined
</label>

<h3 style="margin-top:25px;">Line Preparation</h3>

<label>
<input type="checkbox" name="operators_ready"
<%= changeover.operators_ready ? "checked" : "" %>>
Operators Allocated
</label><br>

<label>
<input type="checkbox" name="workstation_ready"
<%= changeover.workstation_ready ? "checked" : "" %>>
Workstations Prepared
</label><br>

<label>
<input type="checkbox" name="line_balance_ready"
<%= changeover.line_balance_ready ? "checked" : "" %>>
Line Balancing Completed
</label>

<div style="margin-top:30px; display:flex; gap:15px;">

<button type="submit"
formaction="/save-readiness/<%= changeover.id %>">
Save Progress
</button>

<button type="submit"
formaction="/start/<%= changeover.id %>">
Start Changeover
</button>

</div>

</form>

</div>

</div>

<script src="/js/sidebar.js"></script>

</body>
</html>