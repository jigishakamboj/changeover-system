<!DOCTYPE html>
<html>
<head>

<title>Production Reports</title>

<link rel="stylesheet" href="/css/style.css">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="/favicon.png" type="image/png">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

</head>

<body>

<div class="topbar">

<button id="menuToggle">☰</button>

<h1>Changeover Monitoring System</h1>

<div class="topbar-right">

<span class="welcome-text">
Welcome, User
</span>

<a href="/" class="logout-btn">
Logout
</a>

</div>

</div>

<div id="overlay"></div>

<div class="sidebar" id="sidebar">
<h2>Changeover</h2>
<ul>
<li><a href="/dashboard">Dashboard</a></li>
<li><a href="/new-changeover">New Changeover</a></li>
<li><a href="/past-changeovers">Past Changeovers</a></li>
<li><a href="/reports">Reports</a></li>
<li><a href="/pending-analysis">
        Post Changeover Analysis
        <span class="notification"><%= pendingCount %></span></a></li>
</ul>
</div>

<div class="main-content">

<!-- KPI CARDS -->

<div class="cards">

<div class="card">
<h3>Total Closed Changeovers</h3>
<p id="totalCO"></p>
</div>

<div class="card">
<h3>Average Changeover Time</h3>
<p id="avgTime"></p>
</div>

<div class="card">
<h3>Average Bucket Loss</h3>
<p id="avgLoss"></p>
</div>

</div>


<!-- CHARTS -->

<div class="card" style="margin-bottom:30px;">
<h3>Changeover Time</h3>
<canvas id="timeChart"></canvas>
</div>


<div class="card">
<h3>Bucket Loss</h3>
<canvas id="lossChart"></canvas>
</div>

<div class="card" style="margin-top:30px;">
<h3>Ramp-Up Days by Style</h3>
<canvas id="rampChart"></canvas>
</div>

</div>


<script>

const changeovers = <%- JSON.stringify(changeovers) %>;

const total = changeovers.length;

const avgTime =
total > 0
? Math.round(changeovers.reduce((s,c)=>s+(c.final_minutes||0),0)/total)
: 0;

const avgLoss =
total > 0
? Math.round(changeovers.reduce((s,c)=>s+(c.bucket_loss||0),0)/total)
: 0;

document.getElementById("totalCO").innerText = total;
document.getElementById("avgTime").innerText = avgTime + " min";
document.getElementById("avgLoss").innerText = avgLoss + " pcs";


const labels = changeovers.map(
c => c.from_style + " → " + c.to_style
);

const setupTimes = changeovers.map(c => c.final_minutes || 0);
const bucketLoss = changeovers.map(c => c.bucket_loss || 0);


new Chart(document.getElementById('timeChart'), {

type:'bar',

data:{
labels:labels,

datasets:[{
label:'Changeover Time (min)',
data:setupTimes
}]

}

});


new Chart(document.getElementById('lossChart'), {

type:'line',

data:{
labels:labels,

datasets:[{
label:'Bucket Loss (pcs)',
data:bucketLoss
}]

}

});

const rampDays = changeovers.map(c => c.ramp_up_days || 0);

new Chart(document.getElementById('rampChart'), {

type:'bar',

data:{
labels:labels,

datasets:[{
label:'Ramp-Up Days',
data:rampDays
}]

}

});

</script>

<script src="/js/sidebar.js"></script>

</body>
</html>
